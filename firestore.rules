// Firestore Security Rules for ClaimGrid Insurance Platform
// Development Mode - Allows read/write access for testing

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================
    // CLAIMS COLLECTION
    // ===============================================
    match /claims/{claimId} {
      // Allow all read operations (for development)
      allow read: if true;
      
      // Allow all write operations (create, update, delete)
      allow write: if true;
    }
    
    // ===============================================
    // FUTURE: Add more collections here
    // ===============================================
    // match /hospitals/{hospitalId} {
    //   allow read, write: if true;
    // }
    
    // match /providers/{providerId} {
    //   allow read, write: if true;
    // }
    
    // match /patients/{patientId} {
    //   allow read, write: if true;
    // }
  }
}

